# ProAI -- Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# JAMAIS committer .env.local

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Database locale (Docker) ---
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/proai

# --- Redis ---
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- LLM Providers ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_LLM_PROVIDER=openai

# --- Auth ---
JWT_SECRET=CHANGE_ME_lance_openssl_rand_base64_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- Stripe ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# --- Monitoring (optionnel en dev) ---
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=
